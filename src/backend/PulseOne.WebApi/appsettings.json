{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "Authority": "<KEY_VAULT_REFERENCE: AzureAd--Authority>",
    "Audience": "<KEY_VAULT_REFERENCE: AzureAd--Audience>",
    "ValidIssuer": "<KEY_VAULT_REFERENCE: AzureAd--ValidIssuer>"
  },
  "ConnectionStrings": {
    "TenantCatalog": "<KEY_VAULT_REFERENCE: ConnectionStrings--TenantCatalog>",
    "Hangfire": "<KEY_VAULT_REFERENCE: ConnectionStrings--Hangfire>",
    "Redis": "<KEY_VAULT_REFERENCE: ConnectionStrings--Redis>"
  },
  "KeyVault": {
    "Uri": "<KEY_VAULT_REFERENCE: https://kv-pulseone-<env>.vault.azure.net/>"
  }
}
